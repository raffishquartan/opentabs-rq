{
  "name": "@opentabs-dev/browser-extension",
  "version": "0.0.48",
  "type": "module",
  "files": [
    "manifest.json",
    "dist/",
    "side-panel/",
    "offscreen/",
    "icons/"
  ],
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --build",
    "build:bundle": "tsx build-extension.ts",
    "build:side-panel": "tsx build-side-panel.ts && npm run build:tailwind",
    "build:tailwind": "npx @tailwindcss/cli -i src/side-panel/styles.css -o dist/side-panel/styles.css --minify",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@opentabs-dev/shared": "*",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/react": "^10.2.13",
    "@storybook/react-vite": "^10.2.13",
    "@tailwindcss/vite": "^4.2.1",
    "@types/chrome": "^0.1.36",
    "@vitejs/plugin-react": "^5.1.4",
    "esbuild": "^0.27.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.2.13",
    "vite": "^7.3.1"
  }
}
