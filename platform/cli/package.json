      "types": "./dist/scaffold.d.ts",
      "import": "./dist/scaffold.js"
    }
  },
  "bin": {
    "opentabs": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build"
  },
  "dependencies": {
    "@opentabs-dev/browser-extension": "^0.0.102",
    "@opentabs-dev/mcp-server": "^0.0.102",
    "@opentabs-dev/plugin-sdk": "^0.0.102",
    "@opentabs-dev/plugin-tools": "^0.0.102",
    "@opentabs-dev/shared": "^0.0.102",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  }
}
