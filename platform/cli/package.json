  "keywords": [
    "opentabs",
    "mcp",
    "mcp-server",
    "modelcontextprotocol",
    "ai-agent",
    "browser",
    "chrome-extension",
    "cli"
  ],
  "version": "0.0.102",
  "license": "MIT",
  "engines": {
    "node": ">= 22.0.0"
  },
  "type": "module",
  "exports": {
