{
  "name": "@opentabs-dev/opentabs-plugin-azure",
  "description": "OpenTabs plugin for Microsoft Azure Portal",
  "version": "0.0.84",
  "type": "module",
  "main": "dist/adapter.iife.js",
  "keywords": [
    "opentabs-plugin",
    "opentabs",
    "mcp",
    "modelcontextprotocol",
    "chrome-extension",
    "ai-agent",
    "browser-automation"
  ],
  "opentabs": {
    "displayName": "Azure Portal",
    "description": "OpenTabs plugin for Microsoft Azure Portal",
    "urlPatterns": [
      "*://portal.azure.com/*"
    ],
    "homepage": "https://portal.azure.com",
    "iconSvg": "<svg viewBox=\"0 0 96 96\" xmlns=\"http://www.w3.org/2000/svg\"> <path d=\"M33.338 6.544h26.038l-27.03 80.912H4.151zm37.861 0H96L63.166 87.456H37.278z\" fill=\"#0078D4\"/> </svg>",
    "iconDarkSvg": "<svg viewBox=\"0 0 96 96\" xmlns=\"http://www.w3.org/2000/svg\"> <path d=\"M33.338 6.544h26.038l-27.03 80.912H4.151zm37.861 0H96L63.166 87.456H37.278z\" fill=\"#0078D4\"/> </svg>"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && opentabs-plugin build",
    "dev": "tsc --watch --preserveWatchOutput & opentabs-plugin build --watch",
    "type-check": "tsc --noEmit",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --fix src/",
    "format:check": "biome format src/",
    "format": "biome format --write src/",
    "check": "npm run build && npm run type-check && npm run lint && npm run format:check"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "dependencies": {
    "@opentabs-dev/plugin-sdk": "^0.0.103"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@opentabs-dev/plugin-tools": "^0.0.103",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opentabs-dev/opentabs.git",
    "directory": "plugins/azure"
  }
}
