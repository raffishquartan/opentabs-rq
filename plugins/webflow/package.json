{
  "name": "@opentabs-dev/opentabs-plugin-webflow",
  "description": "OpenTabs plugin for Webflow",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.83",
  "type": "module",
  "main": "dist/adapter.iife.js",
  "keywords": [
    "opentabs-plugin",
    "opentabs",
    "mcp",
    "modelcontextprotocol",
    "chrome-extension",
    "ai-agent",
    "browser-automation"
  ],
  "opentabs": {
    "displayName": "Webflow",
    "description": "OpenTabs plugin for Webflow",
    "urlPatterns": [
      "*://*.webflow.com/*"
