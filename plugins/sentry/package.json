{
  "name": "@opentabs-dev/opentabs-plugin-sentry",
  "description": "OpenTabs plugin for Sentry",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.83",
  "type": "module",
  "main": "dist/adapter.iife.js",
