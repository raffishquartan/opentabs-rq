{
  "name": "slack",
  "version": "0.0.1",
  "displayName": "Slack",
  "description": "OpenTabs plugin for Slack",
  "url_patterns": [
    "*://*.slack.com/*"
  ],
  "tools": [
    {
      "name": "send_message",
      "description": "Send a message to a Slack channel or thread",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID to send the message to (e.g., C01234567)"
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "Message text to send — supports Slack mrkdwn formatting"
          },
          "thread_ts": {
            "description": "Thread timestamp to reply in a thread — pass the ts of the parent message",
            "type": "string"
          }
        },
        "required": [
          "channel",
          "text"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID the message was posted to"
          },
          "ts": {
            "type": "string",
            "description": "Timestamp of the posted message — used as a unique message ID"
          }
        },
        "required": [
          "channel",
          "ts"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "edit_message",
      "description": "Edit an existing Slack message. The caller must be the original author of the message.",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID where the message is located (e.g., C01234567)"
          },
          "ts": {
            "type": "string",
            "minLength": 1,
            "description": "Timestamp of the message to edit — serves as the unique message ID (e.g., 1234567890.123456)"
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "New message text — replaces the entire message content. Supports Slack mrkdwn formatting."
          }
        },
        "required": [
          "channel",
          "ts",
          "text"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID of the edited message"
          },
          "ts": {
            "type": "string",
            "description": "Timestamp of the edited message"
          },
          "text": {
            "type": "string",
            "description": "Updated message text as rendered by Slack"
          }
        },
        "required": [
          "channel",
          "ts",
          "text"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "delete_message",
      "description": "Delete a Slack message. The caller must be the original author, or the channel must allow message deletion.",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID where the message is located (e.g., C01234567)"
          },
          "ts": {
            "type": "string",
            "minLength": 1,
            "description": "Timestamp of the message to delete — serves as the unique message ID (e.g., 1234567890.123456)"
          }
        },
        "required": [
          "channel",
          "ts"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "Channel ID of the deleted message"
          },
          "ts": {
            "type": "string",
            "description": "Timestamp of the deleted message"
          }
        },
        "required": [
          "channel",
          "ts"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "read_messages",
      "description": "Read recent messages from a Slack channel with optional date-range filtering and pagination",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID to read messages from (e.g., C01234567)"
          },
          "limit": {
            "description": "Maximum number of messages to return (default 20, max 1000)",
            "type": "integer",
            "minimum": 1,
            "maximum": 1000
          },
          "oldest": {
            "description": "Only return messages after this Unix timestamp (inclusive) — e.g., \"1234567890.123456\"",
            "type": "string"
          },
          "latest": {
            "description": "Only return messages before this Unix timestamp (inclusive) — e.g., \"1234567890.123456\"",
            "type": "string"
          },
          "cursor": {
            "description": "Pagination cursor from a previous response for fetching the next page",
            "type": "string"
          }
        },
        "required": [
          "channel"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Message type (e.g., \"message\")"
                },
                "user": {
                  "description": "User ID who sent the message",
                  "type": "string"
                },
                "text": {
                  "type": "string",
                  "description": "Message text content"
                },
                "ts": {
                  "type": "string",
                  "description": "Message timestamp — unique message identifier"
                }
              },
              "required": [
                "type",
                "text",
                "ts"
              ],
              "additionalProperties": false
            },
            "description": "Array of messages in reverse chronological order"
          },
          "response_metadata": {
            "description": "Pagination metadata",
            "type": "object",
            "properties": {
              "next_cursor": {
                "type": "string",
                "description": "Cursor for the next page of results — empty string if no more pages"
              }
            },
            "required": [
              "next_cursor"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "messages"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "read_thread",
      "description": "Read replies in a Slack thread. Returns all messages including the parent message, with optional pagination.",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID containing the thread (e.g., C01234567)"
          },
          "ts": {
            "type": "string",
            "minLength": 1,
            "description": "Timestamp of the parent message (thread_ts)"
          },
          "limit": {
            "description": "Maximum number of replies to return (default 20, max 1000)",
            "type": "integer",
            "minimum": 1,
            "maximum": 1000
          },
          "cursor": {
            "description": "Pagination cursor from a previous response",
            "type": "string"
          }
        },
        "required": [
          "channel",
          "ts"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Message type (e.g., \"message\")"
                },
                "user": {
                  "description": "User ID who sent the message",
                  "type": "string"
                },
                "text": {
                  "type": "string",
                  "description": "Message text content"
                },
                "ts": {
                  "type": "string",
                  "description": "Message timestamp — unique message identifier"
                },
                "thread_ts": {
                  "description": "Parent message timestamp",
                  "type": "string"
                }
              },
              "required": [
                "type",
                "text",
                "ts"
              ],
              "additionalProperties": false
            },
            "description": "Array of thread replies including the parent message"
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more replies to fetch"
          },
          "response_metadata": {
            "description": "Pagination metadata",
            "type": "object",
            "properties": {
              "next_cursor": {
                "type": "string",
                "description": "Cursor for the next page of results — empty string if no more pages"
              }
            },
            "required": [
              "next_cursor"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "messages",
          "has_more"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "search_messages",
      "description": "Search for messages across Slack channels with optional pagination and sorting",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "description": "Search query string — supports Slack search modifiers (e.g., \"from:@user in:#channel\")"
          },
          "count": {
            "description": "Number of results to return per page (default 20)",
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "page": {
            "description": "Page number of results to return (default 1)",
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "sort": {
            "description": "Sort field — relevance or recency (default \"score\")",
            "type": "string",
            "enum": [
              "score",
              "timestamp"
            ]
          },
          "sort_dir": {
            "description": "Sort direction (default \"desc\")",
            "type": "string",
            "enum": [
              "asc",
              "desc"
            ]
          }
        },
        "required": [
          "query"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "object",
            "properties": {
              "total": {
                "type": "number",
                "description": "Total number of matching messages"
              },
              "matches": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "channel": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "Channel ID where the message was found"
                        },
                        "name": {
                          "type": "string",
                          "description": "Channel name"
                        }
                      },
                      "required": [
                        "id",
                        "name"
                      ],
                      "additionalProperties": false,
                      "description": "Channel information"
                    },
                    "username": {
                      "type": "string",
                      "description": "Username of the message author"
                    },
                    "text": {
                      "type": "string",
                      "description": "Message text content"
                    },
                    "ts": {
                      "type": "string",
                      "description": "Message timestamp"
                    },
                    "permalink": {
                      "type": "string",
                      "description": "Permanent link to the message"
                    }
                  },
                  "required": [
                    "channel",
                    "username",
                    "text",
                    "ts",
                    "permalink"
                  ],
                  "additionalProperties": false
                },
                "description": "Array of matching messages"
              },
              "paging": {
                "description": "Pagination metadata",
                "type": "object",
                "properties": {
                  "count": {
                    "type": "number",
                    "description": "Number of results per page"
                  },
                  "total": {
                    "type": "number",
                    "description": "Total number of matching messages"
                  },
                  "page": {
                    "type": "number",
                    "description": "Current page number"
                  },
                  "pages": {
                    "type": "number",
                    "description": "Total number of pages"
                  }
                },
                "required": [
                  "count",
                  "total",
                  "page",
                  "pages"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "total",
              "matches"
            ],
            "additionalProperties": false,
            "description": "Search results"
          }
        },
        "required": [
          "messages"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "list_channels",
      "description": "List channels in the Slack workspace with optional pagination",
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "description": "Maximum number of channels to return (default 100, max 1000)",
            "type": "integer",
            "minimum": 1,
            "maximum": 1000
          },
          "types": {
            "description": "Comma-separated channel types to include (default \"public_channel\" — options: public_channel, private_channel, mpim, im)",
            "type": "string"
          },
          "cursor": {
            "description": "Pagination cursor from a previous response for fetching the next page",
            "type": "string"
          },
          "exclude_archived": {
            "description": "Set to true to exclude archived channels from results (default false)",
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "channels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Channel ID (e.g., C01234567)"
                },
                "name": {
                  "type": "string",
                  "description": "Channel name without the # prefix"
                },
                "is_channel": {
                  "type": "boolean",
                  "description": "Whether this is a public channel"
                },
                "is_private": {
                  "type": "boolean",
                  "description": "Whether this is a private channel"
                },
                "num_members": {
                  "type": "number",
                  "description": "Number of members in the channel"
                },
                "topic": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "description": "Channel topic text"
                    }
                  },
                  "required": [
                    "value"
                  ],
                  "additionalProperties": false,
                  "description": "Channel topic"
                },
                "purpose": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "description": "Channel purpose text"
                    }
                  },
                  "required": [
                    "value"
                  ],
                  "additionalProperties": false,
                  "description": "Channel purpose"
                }
              },
              "required": [
                "id",
                "name",
                "is_channel",
                "is_private",
                "num_members",
                "topic",
                "purpose"
              ],
              "additionalProperties": false
            },
            "description": "Array of channels matching the filter criteria"
          },
          "response_metadata": {
            "description": "Pagination metadata",
            "type": "object",
            "properties": {
              "next_cursor": {
                "type": "string",
                "description": "Cursor for the next page of results — empty string if no more pages"
              }
            },
            "required": [
              "next_cursor"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "channels"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "get_channel_info",
      "description": "Get detailed information about a Slack channel including topic, purpose, and member count",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID to get info for (e.g., C01234567)"
          }
        },
        "required": [
          "channel"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Channel ID (e.g., C01234567)"
              },
              "name": {
                "type": "string",
                "description": "Channel name without the # prefix"
              },
              "is_channel": {
                "type": "boolean",
                "description": "Whether this is a public channel"
              },
              "is_private": {
                "type": "boolean",
                "description": "Whether this is a private channel"
              },
              "num_members": {
                "type": "number",
                "description": "Number of members in the channel"
              },
              "topic": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string",
                    "description": "Channel topic text"
                  }
                },
                "required": [
                  "value"
                ],
                "additionalProperties": false,
                "description": "Channel topic"
              },
              "purpose": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string",
                    "description": "Channel purpose text"
                  }
                },
                "required": [
                  "value"
                ],
                "additionalProperties": false,
                "description": "Channel purpose"
              }
            },
            "required": [
              "id",
              "name",
              "is_channel",
              "is_private",
              "num_members",
              "topic",
              "purpose"
            ],
            "additionalProperties": false,
            "description": "Detailed channel information"
          }
        },
        "required": [
          "channel"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "create_channel",
      "description": "Create a new public or private Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "pattern": "^[a-z0-9][a-z0-9_-]*$",
            "description": "Name for the new channel — must be lowercase, no spaces, max 80 chars (e.g., \"project-updates\")"
          },
          "is_private": {
            "description": "Whether to create a private channel (default false — creates public channel)",
            "type": "boolean"
          },
          "topic": {
            "description": "Initial topic for the channel (max 250 chars)",
            "type": "string",
            "minLength": 1,
            "maxLength": 250
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "ID of the newly created channel"
              },
              "name": {
                "type": "string",
                "description": "Name of the created channel"
              },
              "is_private": {
                "type": "boolean",
                "description": "Whether the channel is private"
              }
            },
            "required": [
              "id",
              "name",
              "is_private"
            ],
            "additionalProperties": false,
            "description": "The newly created channel"
          },
          "warning": {
            "description": "Warning message if the channel was created but setting the topic failed",
            "type": "string"
          }
        },
        "required": [
          "channel"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_channel_topic",
      "description": "Set the topic of a Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID to set the topic for (e.g., C01234567)"
          },
          "topic": {
            "type": "string",
            "minLength": 1,
            "maxLength": 250,
            "description": "New topic text for the channel (max 250 chars)"
          }
        },
        "required": [
          "channel",
          "topic"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "description": "The topic text that was set"
              },
              "creator": {
                "type": "string",
                "description": "User ID who set the topic"
              },
              "last_set": {
                "type": "number",
                "description": "Unix timestamp of when the topic was last set"
              }
            },
            "required": [
              "value",
              "creator",
              "last_set"
            ],
            "additionalProperties": false,
            "description": "Topic metadata"
          }
        },
        "required": [
          "topic"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_channel_purpose",
      "description": "Set the purpose of a Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID to set the purpose for (e.g., C01234567)"
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 250,
            "description": "New purpose text for the channel (max 250 chars)"
          }
        },
        "required": [
          "channel",
          "purpose"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "purpose": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "description": "The purpose text that was set"
              },
              "creator": {
                "type": "string",
                "description": "User ID who set the purpose"
              },
              "last_set": {
                "type": "number",
                "description": "Unix timestamp of when the purpose was last set"
              }
            },
            "required": [
              "value",
              "creator",
              "last_set"
            ],
            "additionalProperties": false,
            "description": "Purpose metadata"
          }
        },
        "required": [
          "purpose"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "invite_to_channel",
      "description": "Invite a user to a Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID to invite the user to (e.g., C01234567)"
          },
          "user": {
            "type": "string",
            "minLength": 1,
            "description": "User ID to invite (e.g., U01234567)"
          }
        },
        "required": [
          "channel",
          "user"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Channel ID the user was invited to"
              },
              "name": {
                "type": "string",
                "description": "Channel name"
              }
            },
            "required": [
              "id",
              "name"
            ],
            "additionalProperties": false,
            "description": "The channel the user was invited to"
          }
        },
        "required": [
          "channel"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "list_members",
      "description": "List member user IDs of a Slack channel with optional pagination. Returns user IDs only — use get_user_profile to resolve a specific user ID to a name/profile, or list_users to get all workspace users with names.",
      "input_schema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel ID to list members for (e.g., C01234567)"
          },
          "limit": {
            "description": "Maximum number of members to return (default 100, max 1000)",
            "type": "integer",
            "minimum": 1,
            "maximum": 1000
          },
          "cursor": {
            "description": "Pagination cursor from a previous response for fetching the next page",
            "type": "string"
          }
        },
        "required": [
          "channel"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "User ID"
            },
            "description": "Array of user IDs who are members of the channel"
          },
          "response_metadata": {
            "description": "Pagination metadata",
            "type": "object",
            "properties": {
              "next_cursor": {
                "type": "string",
                "description": "Cursor for the next page of results — empty string if no more pages"
              }
            },
            "required": [
              "next_cursor"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "members"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "get_user_profile",
      "description": "Retrieve a Slack user's profile information by user ID",
      "input_schema": {
        "type": "object",
        "properties": {
