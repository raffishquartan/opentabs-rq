  },
  "devDependencies": {
    "@opentabs-dev/plugin-tools": "^0.0.104",
    "@biomejs/biome": "2.4.6",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
