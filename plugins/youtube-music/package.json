{
  "name": "@opentabs-dev/opentabs-plugin-youtube-music",
  "description": "OpenTabs plugin for YouTube Music",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.83",
  "type": "module",
  "main": "dist/adapter.iife.js",
  "keywords": [
    "opentabs-plugin",
    "opentabs",
    "mcp",
    "modelcontextprotocol",
    "chrome-extension",
    "ai-agent",
    "browser-automation"
  ],
  "opentabs": {
    "displayName": "YouTube Music",
    "description": "OpenTabs plugin for YouTube Music",
    "urlPatterns": [
      "*://music.youtube.com/*"
    ],
