{
  "name": "@opentabs-dev/opentabs-plugin-figma",
  "description": "OpenTabs plugin for Figma",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.83",
  "type": "module",
  "main": "dist/adapter.iife.js",
  "keywords": [
    "opentabs-plugin",
    "opentabs",
    "mcp",
    "modelcontextprotocol",
    "chrome-extension",
    "ai-agent",
    "browser-automation"
  ],
  "opentabs": {
    "displayName": "Figma",
    "description": "OpenTabs plugin for Figma",
    "urlPatterns": [
      "*://*.figma.com/*"
    ],
