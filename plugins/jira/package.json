{
  "name": "@opentabs-dev/opentabs-plugin-jira",
  "description": "OpenTabs plugin for Jira",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.84",
  "type": "module",
  "main": "dist/adapter.iife.js",
  "keywords": [
    "opentabs-plugin",
    "opentabs",
    "mcp",
    "modelcontextprotocol",
    "chrome-extension",
    "ai-agent",
    "browser-automation"
  ],
  "opentabs": {
    "displayName": "Jira",
    "description": "OpenTabs plugin for Jira",
    "urlPatterns": [
      "*://*.atlassian.net/*"
    ],
    "excludePatterns": [
      "*://*.atlassian.net/wiki/*"
    ],
    "configSchema": {
      "instanceUrl": {
        "type": "url",
        "label": "Jira URL",
        "description": "The URL of your self-hosted Jira instance (e.g., https://jira.example.com). Leave empty to use Jira Cloud on atlassian.net.",
        "required": false,
        "placeholder": "https://jira.example.com"
      }
    },
