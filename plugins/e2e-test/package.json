{
  "name": "@opentabs-dev/opentabs-plugin-e2e-test",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.83",
  "type": "module",
  "main": "dist/adapter.iife.js",
  "keywords": [
    "opentabs-plugin"
  ],
  "opentabs": {
    "displayName": "E2E Test",
    "description": "Dead-simple plugin for E2E testing — relays to a local test web server",
    "urlPatterns": [
      "http://localhost/*"
    ],
    "homepage": "http://localhost:9876",
    "configSchema": {
      "instanceUrl": {
        "type": "url",
        "label": "Instance URL",
        "description": "URL of the test server instance",
        "required": false,
        "placeholder": "http://localhost:9876"
      },
      "testString": {
        "type": "string",
        "label": "Test String",
        "description": "A test string for config verification",
        "required": false
      }
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && opentabs-plugin build",
    "dev": "tsc --watch --preserveWatchOutput & opentabs-plugin build --watch",
    "type-check": "tsc --noEmit",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --fix src/",
    "format:check": "biome format src/",
    "format": "biome format --write src/",
    "check": "npm run build && npm run type-check && npm run lint && npm run format:check"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "dependencies": {
    "@opentabs-dev/plugin-sdk": "^0.0.81"
  },
  "devDependencies": {
    "@opentabs-dev/plugin-tools": "^0.0.81",
    "@biomejs/biome": "2.4.6",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "license": "MIT"
}
