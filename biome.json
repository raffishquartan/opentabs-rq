{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/build",
      "!**/*.tsbuildinfo",
      "!playwright-report",
      "!test-results",
      "!plugins",
      "!docs",
      "!**/storybook-static",
      "!**/.storybook/**/*.mjs",
      "!.ralph/worktrees",
      "!.claude/worktrees",
      "!.tmp",
      "!.playwright-browsers",
      "!marketing/state.json",
      "!marketing/logs",
      "!.opencode",
      "!platform/browser-extension/side-panel/**/*.js",
      "!platform/browser-extension/side-panel/**/*.css",
      "!**/*.css"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "trailingCommas": "all",
      "semicolons": "always",
      "quoteStyle": "single",
      "arrowParentheses": "asNeeded",
      "bracketSameLine": true
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "domains": {
      "react": "recommended"
    },
    "rules": {
      "recommended": true,
      "suspicious": {
        "noDoubleEquals": "error",
        "noVar": "error",
        "noAssignInExpressions": "off",
        "noImplicitAnyLet": "off",
        "noArrayIndexKey": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "a11y": {
        "noStaticElementInteractions": "off",
        "useAnchorContent": "off",
        "useSemanticElements": "off",
        "useFocusableInteractive": "off",
        "useAriaPropsForRole": "off"
      },
      "style": {
        "useConst": "error",
        "useImportType": "error",
        "useExportType": "error",
        "useConsistentArrowReturn": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "error"
      },
      "nursery": {
        "useSortedClasses": "error"
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [":URL:", ":NODE:", ":PACKAGE:", "@*/**", ":PATH:"]
          }
        }
      }
    }
  }
}
