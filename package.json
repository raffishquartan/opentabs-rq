{
  "name": "opentabs",
  "description": "Turns tabs into tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opentabs-dev/opentabs"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": ">= 22.0.0"
  },
  "workspaces": [
    "platform/*"
  ],
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "tsc --build && npm run --prefix platform/browser-extension build:bundle && npm run --prefix platform/browser-extension build:side-panel && tsx scripts/generate-icons.ts && tsx scripts/install-extension.ts",
    "build:force": "tsc --build --force && npm run --prefix platform/browser-extension build:bundle && npm run --prefix platform/browser-extension build:side-panel && tsx scripts/generate-icons.ts && tsx scripts/install-extension.ts",
    "type-check": "tsc --build --noEmit",
    "type-check:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --cache --cache-location node_modules/.cache/.prettiercache \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "knip": "knip",
    "check": "npm run build && npm run lint && npm run format:check && npm run knip && npm run test",
    "check:everything": "npm run check && npm run test:e2e && npm run check:docs && npm run check:plugins",
    "test": "vitest run",
    "test:e2e": "cd plugins/e2e-test && npm ci && OPENTABS_CONFIG_DIR=/tmp/opentabs-e2e-prebuild npm run build && cd ../.. && npx playwright test",
    "dev:docs": "npm run --prefix docs dev",
    "build:docs": "npm run --prefix docs build",
    "lint:docs": "npm run --prefix docs lint",
    "type-check:docs": "npm run --prefix docs type-check",
    "check:docs": "npm run --prefix docs check",
    "build:plugins": "tsx scripts/plugins.ts --build",
    "check:plugins": "tsx scripts/plugins.ts --check",
    "dev:mcp": "tsx scripts/dev-mcp.ts",
    "storybook": "npm run --prefix platform/browser-extension storybook",
    "clean": "tsx scripts/clean.ts",
    "clean:all": "tsx scripts/clean.ts --all",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/cli": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^13.0.6",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "minimatch": "^10.2.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "lint-staged": {
    "*.{ts,tsx,json}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
