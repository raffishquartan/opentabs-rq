{
  "name": "opentabs",
  "description": "Turns tabs into tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opentabs-dev/opentabs"
  },
  "private": true,
  "type": "module",
  "workspaces": [
    "platform/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "build": "tsc --build --force && bun run --cwd platform/browser-extension build:bundle && bun run --cwd platform/browser-extension build:side-panel && bun run build:icons && bun run build:install-extension",
    "build:icons": "bun scripts/generate-icons.ts",
    "build:install-extension": "bun scripts/install-extension.ts",
    "type-check": "tsc --build",
    "type-check:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --cache --cache-location node_modules/.cache/.prettiercache \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "knip": "knip",
    "check": "bun run build && bun run type-check && bun run lint && bun run knip && bun run test",
    "check:all": "bun run build && bun run type-check && bun run type-check:e2e && bun run lint && bun run knip && bun run test && bun run test:e2e",
    "test": "bun test platform/",
    "test:e2e": "bunx playwright test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/cli": "^4.1.18",
    "@types/chrome": "^0.1.36",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.56.0",
    "bun-types": "^1.3.9",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "lint-staged": {
    "*.{ts,tsx,json}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
